{
  "expo": {
    "name": "Fitloop",
    "slug": "fitloop",
    "version": "1.0.0",
    "orientation": "default",
    "updates": {
      "url": "https://u.expo.dev/f5243a34-96e2-4b2d-ba9d-7e0f3e2829aa"
    },
    "runtimeVersion": "1.0.0",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "fitloop",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fitloop"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon-foreground.png",
        "backgroundImage": "./assets/adaptive-icon-background.png"
      },
      "package": "com.fitloop"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-asset",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0C0D10",
          "image": "./assets/splash-icon.png"
        }
      ],
      "expo-sqlite",
      "expo-font",
      "expo-sharing",
      "expo-updates"
    ],
    "extra": {
      "eas": {
        "projectId": "f5243a34-96e2-4b2d-ba9d-7e0f3e2829aa"
      }
    },
    "owner": "srnanvare007"
  }
}
